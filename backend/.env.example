# ----------------------------------------------------------
# Copy this file to ".env" and fill in your key:
#     cp .env.example .env
# Get a free Groq key at: https://console.groq.com/keys
# (The app also runs WITHOUT a key in a built-in demo mode.)
# ----------------------------------------------------------
GROQ_API_KEY=

# Optional overrides --------------------------------------
# Rename the assistant everywhere (UI + replies):
ASSISTANT_NAME=ChatBot
DEFAULT_MODEL=llama-3.3-70b-versatile
DEFAULT_TEMPERATURE=0.7
DATABASE_URL=sqlite:////app/data/chat.db
CORS_ORIGINS=*
DEBUG=false

# File uploads --------------------------------------------
MAX_UPLOAD_MB=20
MAX_DOC_CHARS=16000
